NEXT_PUBLIC_API_URL=http://localhost:8080

# =============================================================================
# GOOGLE MAPS — FRONTEND (clave pública)
# =============================================================================
# Consola: https://console.cloud.google.com/google/maps-apis/credentials
#
# 1. Crear proyecto y vincular cuenta de facturación (obligatorio).
# 2. Habilitar APIs:
#    - Maps JavaScript API
#    - Places API (New)
# 3. Crear API key → Restricción "Sitios web (referrers HTTP)":
#    Desarrollo:  http://localhost:3000/*
#    Producción:  https://sistema.soderiadonjavier.com/*
# 4. Pegar la clave aquí y reiniciar `npm run dev`.
#
NEXT_PUBLIC_GOOGLE_MAPS_API_KEY=

# Misma clave pública VAPID que VAPID_PUBLIC_KEY del backend (alertas push Android)
# NEXT_PUBLIC_VAPID_PUBLIC_KEY=
